{
  "name": "{{projectName}}-server",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test 'src/**/*.test.js' '../shared/**/*.test.js'"
  },
  "dependencies": {
    "@domount/shuttle": "{{shuttle}}"
  },
  "imports": {
    "#server/*": "./src/*",
    "#shared/*": "../shared/*"
  },
  "engines": {
    "node": ">=18"
  }
}
