{
  "name": "{{projectName}}",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "npm install --prefix server && npm install --prefix web",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix web\"",
    "test": "cd server && npm test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:boundaries": "shuttle-check-boundaries",
    "verify": "shuttle-verify",
    "verify:all": "shuttle-verify --all",
    "scaffold:feature": "shuttle-scaffold-feature",
    "scaffold:api": "shuttle-scaffold-api",
    "scaffold:skill": "shuttle-scaffold-skill"
  },
  "devDependencies": {
    "@domount/shuttle": "{{shuttle}}",
    "@eslint/js": "^9.39.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^15.15.0",
    "typescript-eslint": "^8.46.4"
  },
  "engines": {
    "node": ">=18"
  }
}
