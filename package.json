{
  "name": "shuttle",
  "private": true,
  "description": "Shuttle — local agentic app framework (normal backend + smart agent backend + web client)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Domount/shuttle.git"
  },
  "homepage": "https://domount.github.io/shuttle/",
  "bugs": {
    "url": "https://github.com/Domount/shuttle/issues"
  },
  "workspaces": [
    "packages/*",
    "cli/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "sync:template": "node scripts/sync-create-shuttle-template.mjs",
    "sync:favicon": "node scripts/sync-favicon.mjs",
    "release": "node scripts/publish-all.mjs",
    "release:dry": "node scripts/publish-all.mjs --dry-run",
    "docs:dev": "vitepress dev website",
    "docs:build": "vitepress build website",
    "docs:preview": "vitepress preview website",
    "build:app": "node scripts/build-default-app.mjs",
    "dev:app": "npm run dev --prefix build/default-app",
    "verify:app": "npm run verify --prefix build/default-app"
  },
  "devDependencies": {
    "sharp": "^0.35.1",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=18"
  }
}
